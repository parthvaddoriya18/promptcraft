# Copy this file to `.env` and fill in your key.
# Only variables prefixed with VITE_ are available in the app (see Vite env docs).

VITE_OPENAI_API_KEY=

# Optional chat model (default: gpt-4o-mini)
# VITE_OPENAI_MODEL=gpt-4o-mini

# Optional: override OpenAI API base URL (defaults: dev uses Vite proxy /api/openai)
# VITE_OPENAI_BASE_URL=
